# AI Trading System — backend environment template.
# Copy to .env (dev), .env.staging, or .env.prod and fill in.
# App settings are read by app/config/settings.py (env_prefix="TW_").
# NEVER commit real secrets — only this example file is tracked.

# ---------------------------------------------------------------------------
# Core application settings (active today)
# ---------------------------------------------------------------------------
# dev | staging | prod
TW_ENVIRONMENT=dev
# Implementation phase gate: 1=MVP 2=Backtest 3=AI 4=Risk/Exec 5=Staging 6=Prod
TW_PHASE=1
# memory | firestore
TW_REPOSITORY_BACKEND=memory
# GCP project for the Firestore backend (leave blank to infer from credentials
# or the emulator). Only used when TW_REPOSITORY_BACKEND=firestore.
TW_FIRESTORE_PROJECT=

# AI provider: mock (deterministic, default) | openai
TW_AI_PROVIDER_BACKEND=mock
TW_OPENAI_MODEL=gpt-5
# AI cost-control gates (see AI_PIPELINE.md)
TW_AI_SCORE_THRESHOLD=50.0
TW_AI_MAX_CONFIDENCE_ADJUSTMENT=0.20

# RAG retrieval (AI_PIPELINE.md 5/8): inject similar prior documents into the
# reasoning prompt. Off by default; embeddings default to the deterministic mock.
TW_RETRIEVAL_ENABLED=false
TW_RETRIEVAL_TOP_K=5
# Embedding backend: mock (deterministic, default) | openai (reuses [openai] extra)
TW_EMBEDDING_BACKEND=mock
TW_EMBEDDING_MODEL=text-embedding-3-large

# Fundamental Engine (TRADING_ENGINE.md 4.4/4.5). Additive quality bias/filter.
# OFF by default -> scoring/decision path byte-for-byte unchanged. When enabled,
# a bounded QualityBias (+/-10%) plus a hard veto (bankruptcy_risk or score below
# the threshold) are applied deterministically before AI.
TW_FUNDAMENTAL_FILTER_ENABLED=false
# Fundamentals backend: mock (deterministic, default) | finnhub (not yet implemented)
TW_FUNDAMENTAL_DATA_BACKEND=mock
TW_FUNDAMENTAL_MIN_SCORE=20.0

# Market Regime Engine (TRADING_ENGINE.md 4.6/7.1). Additive, market-wide.
# OFF by default -> risk_multiplier effectively 1.0, sizing/exposure unchanged.
# When enabled, the regime risk_multiplier (0.5-1.5) scales position sizing and a
# low exposure_recommendation tightens the open-position cap (after AI).
TW_REGIME_ADJUSTMENT_ENABLED=false
# Macro/regime backend: mock (deterministic, default) | ibkr (not yet implemented)
TW_REGIME_DATA_BACKEND=mock
# Open-position cap multiplier applied when exposure_recommendation == low.
TW_REGIME_LOW_EXPOSURE_POSITION_RATIO=0.5

# Broker + market-data: mock (deterministic, default) | ibkr
# The IBKR adapters connect to a local TWS / IB Gateway (only used when set to
# ibkr). Distinct client ids keep the broker and market-data sessions separate.
TW_BROKER_BACKEND=mock
TW_MARKET_DATA_BACKEND=mock
TW_IBKR_HOST=127.0.0.1
TW_IBKR_PORT=7497
TW_IBKR_BROKER_CLIENT_ID=1
TW_IBKR_MARKET_DATA_CLIENT_ID=2

# ---------------------------------------------------------------------------
# Local Firestore emulator (dev only) — read directly by the google SDK
# ---------------------------------------------------------------------------
# FIRESTORE_EMULATOR_HOST=localhost:8080
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ---------------------------------------------------------------------------
# External service secrets. The OpenAI and IBKR adapters are wired behind their
# seams (select via the backend settings above); they default to mocks until a
# live backend is chosen. The Finnhub seam still uses the deterministic mock.
# IBKR auth is handled by the local TWS / IB Gateway session (host/port above),
# not an API key. The OpenAI SDK reads OPENAI_API_KEY from the environment.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
# FINNHUB_API_KEY=
